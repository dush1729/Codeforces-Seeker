rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Daily problems and leaderboard: anyone can read
    match /dailyProblems/{date} {
      allow read: if true;
      allow write: if false;
    }

    match /dailyLeaderboard/{date} {
      allow read: if true;
      allow write: if false;
    }

    // Cumulative leaderboard: anyone can read
    match /cumulativeLeaderboard/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Users: anyone can read/write (registration from app)
    match /users/{handle} {
      allow read, write: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
